<%- include('../partials/header') %>

<section class="card glass-panel">
	<h1>Contact Form Submissions</h1>
	<p>Review and respond to incoming public inquiries.</p>
</section>

<section class="card glass-panel">
	<% const filterValues = (typeof filters !== 'undefined' && filters) ? filters : {}; %>
	<% const currentRoleForFilters = user && (user.roleName || user.account_type || user.role); %>
	<% const submissionsPath = currentRoleForFilters === 'Admin' ? '/admin/contact-form-submissions' : '/employee/contact-form-submissions'; %>
	<form method="GET" action="<%= submissionsPath %>" style="display:flex; flex-wrap:wrap; gap:0.75rem 1rem; align-items:flex-end;">
		<div style="display:grid; gap:0.35rem; min-width:170px; flex:0 1 210px;">
			<label for="sortBy">Sort By</label>
			<select id="sortBy" name="sortBy">
				<option value="newest" <%= filterValues.sortBy === 'newest' ? 'selected' : '' %>>Newest</option>
				<option value="oldest" <%= filterValues.sortBy === 'oldest' ? 'selected' : '' %>>Oldest</option>
				<option value="sender" <%= filterValues.sortBy === 'sender' ? 'selected' : '' %>>Sender</option>
			</select>
		</div>

		<div style="display:grid; gap:0.35rem; min-width:170px; flex:0 1 210px;">
			<label for="readStatus">Filter Status</label>
			<select id="readStatus" name="readStatus">
				<option value="" <%= !filterValues.readStatus ? 'selected' : '' %>>All</option>
				<option value="open" <%= String(filterValues.readStatus || '').toLowerCase() === 'open' ? 'selected' : '' %>>Open</option>
				<option value="read" <%= String(filterValues.readStatus || '').toLowerCase() === 'read' ? 'selected' : '' %>>Read</option>
			</select>
		</div>

		<div style="display:grid; gap:0.35rem; min-width:220px; flex:1 1 320px; max-width:420px;">
			<label for="q">Keyword</label>
			<input id="q" name="q" type="text" value="<%= filterValues.q || '' %>" placeholder="Search sender, email, or message">
		</div>

		<div style="display:flex; gap:0.5rem; align-items:center;">
			<button type="submit" class="btn btn-primary">Apply</button>
			<a href="<%= submissionsPath %>" class="btn">Reset</a>
		</div>
	</form>
</section>

<section class="card glass-panel">
	<% const messages = Array.isArray(contactForms) ? contactForms : []; %>
	<% const currentRole = user && (user.roleName || user.account_type || user.role); %>
	<% const isStaffUser = currentRole === 'Admin' || currentRole === 'Employee'; %>
	<% const deleteBasePath = currentRole === 'Admin' ? '/admin/contact-messages' : '/employee/contact-messages'; %>
	<% const readBasePath = currentRole === 'Admin' ? '/admin/contact-messages' : '/employee/contact-messages'; %>
	<% const returnToPath = currentRole === 'Admin' ? '/admin/contact-form-submissions' : '/employee/contact-form-submissions'; %>
	<% if (messages.length > 0) { %>
		<table style="width:100%; border-collapse: collapse;">
			<thead>
				<tr>
					<th style="text-align:left; padding: 0.5rem;">Status</th>
					<th style="text-align:left; padding: 0.5rem;">Sender</th>
					<th style="text-align:left; padding: 0.5rem;">Email</th>
					<th style="text-align:left; padding: 0.5rem;">Message</th>
					<th style="text-align:left; padding: 0.5rem;">Submitted</th>
					<% if (isStaffUser) { %>
						<th style="text-align:left; padding: 0.5rem;">Actions</th>
					<% } %>
				</tr>
			</thead>
			<tbody>
				<% messages.forEach((item) => { %>
					<tr>
						<td style="padding: 0.5rem;"><%= item.isRead ? 'Read' : 'Open' %></td>
						<td style="padding: 0.5rem;"><%= item.senderName || 'Unknown Sender' %></td>
						<td style="padding: 0.5rem;"><%= item.senderEmail || 'No email provided' %></td>
						<td style="padding: 0.5rem;"><%= item.message %></td>
						<td style="padding: 0.5rem;"><%= item.submitted ? new Date(item.submitted).toLocaleString() : 'N/A' %></td>
						<% if (isStaffUser) { %>
							<td style="padding: 0.5rem;">
								<% if (!item.isRead) { %>
									<form action="<%= readBasePath %>/<%= item.id %>/read" method="POST" style="display:inline-block; margin-right: 0.35rem;">
										<input type="hidden" name="returnTo" value="<%= returnToPath %>">
										<button type="submit" class="btn btn-primary">Mark as Read</button>
									</form>
								<% } %>
								<form action="<%= deleteBasePath %>/<%= item.id %>/delete" method="POST" style="display:inline-block;">
									<input type="hidden" name="returnTo" value="<%= returnToPath %>">
									<button type="submit" class="btn">Delete</button>
								</form>
							</td>
						<% } %>
					</tr>
				<% }) %>
			</tbody>
		</table>
	<% } else { %>
		<p>No contact messages found.</p>
	<% } %>
</section>

<%- include('../partials/footer') %>
