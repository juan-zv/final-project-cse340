<%- include('../partials/header') %>

<section class="card glass-panel">
	<h1>User Dashboard</h1>
	<p>
		Welcome
		<strong><%= user && user.name ? user.name : 'Driver' %></strong>.
		Manage your reviews and service requests here.
	</p>
</section>

<section class="card glass-panel">
	<h2>Review Tools</h2>
	<p>Leave reviews on vehicles you have driven and manage your own posts.</p>
	<a href="/reviews/new" class="btn btn-primary">Write a Review</a>
	<a href="/reviews" class="btn">View My Reviews</a>
</section>

<section class="card glass-panel">
	<h2>Service Request Tools</h2>
	<p>Submit new requests (oil change, inspection, brake check) and track each status update.</p>
	<a href="/services" class="btn btn-primary">Open Service Center</a>
	<a href="/services/request" class="btn">Submit Service Request</a>
</section>

<section class="card glass-panel">
	<h2>Recent Service Status</h2>
	<% const myRequests = (typeof serviceRequests !== 'undefined' && Array.isArray(serviceRequests)) ? serviceRequests : []; %>
	<% if (myRequests.length > 0) { %>
		<table style="width:100%; border-collapse: collapse;">
			<thead>
				<tr>
					<th style="text-align:left; padding: 0.5rem;">Type</th>
					<th style="text-align:left; padding: 0.5rem;">Status</th>
					<th style="text-align:left; padding: 0.5rem;">Date</th>
				</tr>
			</thead>
			<tbody>
				<% myRequests.forEach((request) => { %>
					<tr>
						<td style="padding: 0.5rem;"><%= request.serviceType || 'General Service' %></td>
						<td style="padding: 0.5rem;"><%= request.serviceStatus || 'Submitted' %></td>
						<td style="padding: 0.5rem;"><%= request.createdAt ? new Date(request.createdAt).toLocaleDateString() : 'N/A' %></td>
					</tr>
				<% }) %>
			</tbody>
		</table>
	<% } else { %>
		<p>No service history yet. Submit your first request to get started.</p>
	<% } %>
</section>

<%- include('../partials/footer') %>
