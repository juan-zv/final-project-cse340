<%- include('../partials/header') %>

<section class="card glass-panel">
	<h1>Submit Service Request</h1>
	<p>Tell us what your vehicle needs, and we will follow up with scheduling details.</p>
</section>

<section class="card glass-panel">
	<form action="/services/request" method="POST">
		<% const selectedInvId = typeof inv_id !== 'undefined' ? inv_id : ''; %>
		<% const allVehicles = Array.isArray(vehicleOptions) ? vehicleOptions : []; %>
		<% const allServices = Array.isArray(serviceOptions) ? serviceOptions : []; %>

		<label for="inv_id">Vehicle</label>
		<select id="inv_id" name="inv_id" required>
			<option value="">Select a vehicle</option>
			<% allVehicles.forEach((vehicle) => { %>
				<option value="<%= vehicle.id %>" <%= String(selectedInvId) === String(vehicle.id) ? 'selected' : '' %>>
					<%= vehicle.name %>
				</option>
			<% }) %>
		</select>

		<label for="service_id">Service Type</label>
		<select id="service_id" name="service_id" required>
			<option value="">Select a service</option>
			<% allServices.forEach((service) => { %>
				<option value="<%= service.service_id %>"><%= service.service_name %></option>
			<% }) %>
		</select>

		<label for="request_notes">Request Notes</label>
		<textarea
			id="request_notes"
			name="request_notes"
			rows="6"
			minlength="10"
			maxlength="2000"
			required
			placeholder="Describe symptoms, preferred timing, and any extra details"
		></textarea>

		<button type="submit" class="btn btn-primary">Send Request</button>
		<a href="/services" class="btn">View Request History</a>
	</form>
</section>

<%- include('../partials/footer') %>
