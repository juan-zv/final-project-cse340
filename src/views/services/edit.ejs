<%- include('../partials/header') %>

<a href="/services" class="btn" style="margin-bottom: 0.75rem;">Back to Services</a>
<section class="card glass-panel">
	<h1>Update Service Request</h1>
	<p>Add notes to your request and delete it if needed.</p>
</section>

<section class="card glass-panel">
	<form action="/services/<%= request && request.requestId ? request.requestId : '' %>/edit" method="POST">
		<% if (managerMode) { %>
			<label for="service_status">Status</label>
			<select id="service_status" name="service_status">
				<option value="Submitted" <%= request && request.serviceStatus === 'Submitted' ? 'selected' : '' %>>Submitted</option>
				<option value="In Progress" <%= request && request.serviceStatus === 'In Progress' ? 'selected' : '' %>>In Progress</option>
				<option value="Completed" <%= request && request.serviceStatus === 'Completed' ? 'selected' : '' %>>Completed</option>
			</select>
		<% } else { %>
			<p><strong>Status:</strong> <%= request && request.serviceStatus ? request.serviceStatus : 'Submitted' %></p>
		<% } %>

		<label for="request_notes">Service Notes</label>
		<textarea
			id="request_notes"
			name="request_notes"
			rows="6"
			maxlength="2000"
			placeholder="Add notes for diagnostics, updates, or completion details"
		><%= request && request.requestNotes ? request.requestNotes : '' %></textarea>

		<button type="submit" class="btn btn-primary">Save Update</button>
		<button type="submit" formaction="/services/<%= request && request.requestId ? request.requestId : '' %>/delete" formmethod="POST" class="btn">Delete Request</button>
	</form>
</section>

<%- include('../partials/footer') %>
