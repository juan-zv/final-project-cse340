<%- include('../partials/header') %>

<section class="card glass-panel">
	<h1>Service Center</h1>
	<p>Choose a service type and submit a request to our team.</p>
</section>

<section class="card glass-panel">
	<h2>Available Services</h2>
	<% const offeredServices = Array.isArray(serviceOptions) ? serviceOptions : []; %>
	<% if (offeredServices.length > 0) { %>
		<table style="width:100%; border-collapse: collapse;">
			<thead>
				<tr>
					<th style="text-align:left; padding: 0.5rem;">Service</th>
					<th style="text-align:left; padding: 0.5rem;">Description</th>
				</tr>
			</thead>
			<tbody>
				<% offeredServices.forEach((service) => { %>
					<tr>
						<td style="padding: 0.5rem;"><%= service.service_name %></td>
						<td style="padding: 0.5rem;"><%= service.service_description || 'No description provided' %></td>
					</tr>
				<% }) %>
			</tbody>
		</table>
	<% } else { %>
		<p>No services are currently configured.</p>
	<% } %>
	<a href="/services/request" class="btn btn-primary">Start Service Request</a>
</section>

<section class="card glass-panel">
	<% const filterValues = (typeof filters !== 'undefined' && filters) ? filters : {}; %>
	<form method="GET" action="/services" style="display:grid; gap:0.75rem;">
		<label for="sortBy">Sort By</label>
		<select id="sortBy" name="sortBy">
			<option value="newest" <%= filterValues.sortBy === 'newest' ? 'selected' : '' %>>Newest</option>
			<option value="oldest" <%= filterValues.sortBy === 'oldest' ? 'selected' : '' %>>Oldest</option>
			<option value="status" <%= filterValues.sortBy === 'status' ? 'selected' : '' %>>Status</option>
			<option value="type" <%= filterValues.sortBy === 'type' ? 'selected' : '' %>>Service Type</option>
		</select>

		<label for="status">Filter Status</label>
		<select id="status" name="status">
			<option value="" <%= !filterValues.status ? 'selected' : '' %>>All</option>
			<option value="open" <%= String(filterValues.status || '').toLowerCase() === 'open' ? 'selected' : '' %>>Open</option>
			<option value="in progress" <%= String(filterValues.status || '').toLowerCase() === 'in progress' ? 'selected' : '' %>>In Progress</option>
			<option value="completed" <%= String(filterValues.status || '').toLowerCase() === 'completed' ? 'selected' : '' %>>Completed</option>
		</select>

		<label for="serviceId">Filter Service</label>
		<select id="serviceId" name="serviceId">
			<option value="" <%= !filterValues.serviceId ? 'selected' : '' %>>All Services</option>
			<% offeredServices.forEach((service) => { %>
				<option value="<%= service.service_id %>" <%= String(filterValues.serviceId || '') === String(service.service_id) ? 'selected' : '' %>><%= service.service_name %></option>
			<% }) %>
		</select>

		<div>
			<button type="submit" class="btn btn-primary">Apply</button>
			<a href="/services" class="btn">Reset</a>
		</div>
	</form>
</section>

<section class="card glass-panel">
	<h2>Your Service Requests</h2>
	<% const requests = Array.isArray(serviceRequests) ? serviceRequests : []; %>
	<% if (requests.length > 0) { %>
		<table style="width:100%; border-collapse: collapse;">
			<thead>
				<tr>
					<th style="text-align:left; padding: 0.5rem;">Type</th>
					<th style="text-align:left; padding: 0.5rem;">Status</th>
					<th style="text-align:left; padding: 0.5rem;">Vehicle</th>
					<th style="text-align:left; padding: 0.5rem;">Notes</th>
					<th style="text-align:left; padding: 0.5rem;">Updated</th>
					<th style="text-align:left; padding: 0.5rem;">Action</th>
				</tr>
			</thead>
			<tbody>
				<% requests.forEach((request) => { %>
					<tr>
						<td style="padding: 0.5rem;"><%= request.serviceName || request.serviceType || 'General Service' %></td>
						<td style="padding: 0.5rem;"><%= request.displayStatus || request.serviceStatus || 'Open' %></td>
						<td style="padding: 0.5rem;"><%= [request.invYear, request.invMake, request.invModel].filter(Boolean).join(' ') || 'Not specified' %></td>
						<td style="padding: 0.5rem;"><%= request.requestNotes || 'No notes yet' %></td>
						<td style="padding: 0.5rem;"><%= request.updatedAt ? new Date(request.updatedAt).toLocaleDateString() : (request.createdAt ? new Date(request.createdAt).toLocaleDateString() : 'N/A') %></td>
						<td style="padding: 0.5rem;">
							<a href="/services/<%= request.requestId %>/edit" class="btn">Open</a>
						</td>
					</tr>
				<% }) %>
			</tbody>
		</table>
	<% } else { %>
		<p>No service requests found yet.</p>
	<% } %>
</section>

<%- include('../partials/footer') %>
