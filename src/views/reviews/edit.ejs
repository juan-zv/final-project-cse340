<%- include('../partials/header') %>

<section class="card glass-panel">
	<h1>Edit Review</h1>
	<p>Update your review content below.</p>
</section>

<section class="card glass-panel">
	<form action="/reviews/<%= review && (review.review_id || review.id) ? (review.review_id || review.id) : '' %>/edit" method="POST">
		<input type="hidden" name="inv_id" value="<%= review && review.inv_id ? review.inv_id : '' %>">

		<label for="review_text">Review Text</label>
		<textarea
			id="review_text"
			name="review_text"
			rows="6"
			minlength="10"
			maxlength="1200"
			required
		><%= review && review.review_text ? review.review_text : '' %></textarea>

		<button type="submit" class="btn btn-primary">Save Changes</button>
		<a href="/reviews" class="btn">Back to Reviews</a>
	</form>
</section>

<%- include('../partials/footer') %>
