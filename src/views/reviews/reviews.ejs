<%- include('../partials/header') %>

<section class="card glass-panel">
	<h1>Vehicle Reviews</h1>
	<p>See what customers are saying and manage your own review history.</p>
	<% if (isLoggedIn) { %>
		<a href="/reviews/new" class="btn btn-primary">Write a New Review</a>
	<% } %>
</section>

<section class="card glass-panel">
	<% const filterValues = (typeof filters !== 'undefined' && filters) ? filters : {}; %>
	<% const isModeratorViewEnabled = !!(typeof isModeratorView !== 'undefined' && isModeratorView); %>
	<form method="GET" action="/reviews" style="display:grid; gap:0.75rem;">
		<label for="sortBy">Sort By</label>
		<select id="sortBy" name="sortBy">
			<option value="newest" <%= filterValues.sortBy === 'newest' ? 'selected' : '' %>>Newest</option>
			<option value="oldest" <%= filterValues.sortBy === 'oldest' ? 'selected' : '' %>>Oldest</option>
			<option value="vehicle" <%= filterValues.sortBy === 'vehicle' ? 'selected' : '' %>>Vehicle</option>
			<% if (isModeratorViewEnabled) { %>
				<option value="reviewer" <%= filterValues.sortBy === 'reviewer' ? 'selected' : '' %>>Reviewer</option>
			<% } %>
		</select>

		<label for="vehicle">Filter Vehicle</label>
		<input id="vehicle" name="vehicle" type="text" value="<%= filterValues.vehicle || '' %>" placeholder="Camry, F-150, etc.">

		<% if (isModeratorViewEnabled) { %>
			<label for="reviewer">Filter Reviewer</label>
			<input id="reviewer" name="reviewer" type="text" value="<%= filterValues.reviewer || '' %>" placeholder="Name or partial name">
		<% } %>

		<label for="q">Keyword</label>
		<input id="q" name="q" type="text" value="<%= filterValues.q || '' %>" placeholder="Search review text">

		<div>
			<button type="submit" class="btn btn-primary">Apply</button>
			<a href="/reviews" class="btn">Reset</a>
		</div>
	</form>
</section>

<section class="card glass-panel">
	<% const allReviews = Array.isArray(reviews) ? reviews : []; %>
	<% if (allReviews.length > 0) { %>
		<% allReviews.forEach((review) => { %>
			<article class="card glass-panel" style="margin: 1rem 0;">
				<h3><%= review.vehicleName || 'Vehicle details unavailable' %></h3>
				<p><%= review.reviewText || '' %></p>
				<p>
					By <%= review.accountFirstName || 'Customer' %>
					on <%= review.reviewDate ? new Date(review.reviewDate).toLocaleDateString() : (review.createdAt ? new Date(review.createdAt).toLocaleDateString() : 'N/A') %>
				</p>

				<% const currentUserId = Number(user && (user.id ?? user.account_id)); %>
				<% const reviewOwnerId = Number(review.accountId); %>
				<% const canEditOwn = Number.isFinite(currentUserId) && currentUserId === reviewOwnerId; %>
				<% const canModerate = role === 'Employee' || role === 'Admin'; %>

				<% if (canEditOwn) { %>
					<a href="/reviews/<%= review.reviewId %>/edit" class="btn">Edit</a>
					<form action="/reviews/<%= review.reviewId %>/delete" method="POST" style="display:inline-block; margin-left: 0.5rem;">
						<input type="hidden" name="returnTo" value="/reviews">
						<button type="submit" class="btn">Delete</button>
					</form>
				<% } %>

				<% if (canModerate && !canEditOwn) { %>
					<form action="/reviews/<%= review.reviewId %>/delete" method="POST" style="display:inline-block; margin-top: 0.5rem;">
						<input type="hidden" name="returnTo" value="/reviews">
						<button type="submit" class="btn">Moderate / Remove</button>
					</form>
				<% } %>
			</article>
		<% }) %>
	<% } else { %>
		<p>No reviews found yet.</p>
	<% } %>
</section>

<%- include('../partials/footer') %>
