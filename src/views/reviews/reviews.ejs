<%- include('../partials/header') %>

<section class="card glass-panel">
	<h1>Vehicle Reviews</h1>
	<p>See what customers are saying and manage your own review history.</p>
	<% if (isLoggedIn) { %>
		<a href="/reviews/new" class="btn btn-primary">Write a New Review</a>
	<% } %>
</section>

<section class="card glass-panel">
	<% const allReviews = Array.isArray(reviews) ? reviews : []; %>
	<% if (allReviews.length > 0) { %>
		<% allReviews.forEach((review) => { %>
			<article class="card glass-panel" style="margin: 1rem 0;">
				<h3>
					<%= review.inv_year || '' %>
					<%= review.inv_make || '' %>
					<%= review.inv_model || '' %>
				</h3>
				<p><%= review.review_text || review.comment || '' %></p>
				<p>
					By <%= review.account_firstname || review.user_name || 'Customer' %>
					on <%= review.review_date ? new Date(review.review_date).toLocaleDateString() : (review.created_at ? new Date(review.created_at).toLocaleDateString() : 'N/A') %>
				</p>

				<% const canEditOwn = user && (user.id === review.account_id || user.account_id === review.account_id); %>
				<% const canModerate = role === 'Employee' || role === 'Admin'; %>

				<% if (canEditOwn) { %>
					<a href="/reviews/<%= review.review_id || review.id %>/edit" class="btn">Edit</a>
					<form action="/reviews/<%= review.review_id || review.id %>/delete" method="POST" style="display:inline-block; margin-left: 0.5rem;">
						<button type="submit" class="btn">Delete</button>
					</form>
				<% } %>

				<% if (canModerate && !canEditOwn) { %>
					<form action="/reviews/<%= review.review_id || review.id %>/delete" method="POST" style="display:inline-block; margin-top: 0.5rem;">
						<button type="submit" class="btn">Moderate / Remove</button>
					</form>
				<% } %>
			</article>
		<% }) %>
	<% } else { %>
		<p>No reviews found yet.</p>
	<% } %>
</section>

<%- include('../partials/footer') %>
