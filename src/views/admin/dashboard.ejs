    <div class="card">
        <h2>Inventory Management</h2>
        <a href="/admin/inventory" class="btn">Manage Inventory (Add/Edit/Delete)</a>
        <a href="/catalog" class="btn-secondary">Browse Inventory</a>
    </div>

    <div class="card">
        <h2>Category Management</h2>
        <a href="/admin/categories" class="btn">Manage Categories (Add/Edit/Delete)</a>
        <a href="/dashboard" class="btn-secondary">Back to Shared Dashboard</a>
    </div>

    <div class="card">
        <h2>Employee Tools</h2>
        <a href="/employee/dashboard" class="btn">Access Employee View</a>
        <a href="/admin/employees" class="btn-secondary">Manage Staff Accounts</a>
    </div>

    <div class="card">
        <h2>System Activity Logs</h2>
		<a href="/services" class="btn">View Service Activity</a>
