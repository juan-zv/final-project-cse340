<%- include('partials/header') %>

<section class="card glass-panel">
    <h1><%= typeof dashboardTitle !== 'undefined' ? dashboardTitle : 'Dashboard' %></h1>
    <% const currentUser = typeof user !== 'undefined' ? user : null; %>
    <p>
        <%= typeof dashboardIntro !== 'undefined' && dashboardIntro
            ? dashboardIntro
            : `Welcome ${currentUser && currentUser.name ? currentUser.name : 'User'}. You are signed in as ${currentUser && currentUser.roleName ? currentUser.roleName : 'User'}.` %>
    </p>
</section>

<% const roleCards = typeof dashboardCards !== 'undefined' && Array.isArray(dashboardCards) ? dashboardCards : []; %>
<% if (roleCards.length > 0) { %>
<section class="card glass-panel">
    <h2><%= typeof dashboardSectionTitle !== 'undefined' ? dashboardSectionTitle : 'Role Tools' %></h2>
    <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 0.7rem;">
        <% roleCards.forEach((card) => { %>
            <a
                href="<%= card.primaryLink || card.secondaryLink || '/dashboard' %>"
                style="display:block; text-decoration:none; color:inherit; border:1px solid rgba(255,255,255,0.14); border-radius:10px; padding:0.7rem 0.75rem; background:rgba(17,25,40,0.45); min-height: 92px;"
            >
                <h3><%= card.title %></h3>
                <% if (card.description) { %>
                    <p style="margin-bottom:0; color: rgba(243, 244, 246, 0.82);"><%= card.description %></p>
                <% } %>
            </a>
        <% }) %>
    </div>
</section>
<% } %>

<% if (typeof showDataModelNotes !== 'undefined' && showDataModelNotes) { %>
<section class="card glass-panel">
    <h2>Required Data Model (Project Scope)</h2>
    <p>The platform is designed around these core tables and relationships:</p>
    <ul style="padding-left: 1.2rem;">
        <li>Users table with a role field (User, Employee, Admin).</li>
        <li>Vehicles table for core listing and pricing data.</li>
        <li>Categories table linked to vehicles.</li>
        <li>Reviews table linked to users and vehicles.</li>
        <li>Service requests table linked to users with status tracking.</li>
        <li>Contact messages table from the public form.</li>
        <li>Vehicle images table with one-to-many relationship to vehicles.</li>
    </ul>
</section>
<% } %>

<%- include('partials/footer') %>
