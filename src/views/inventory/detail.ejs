<%- include('../partials/header') %>

<div class="vehicle-detail">
    <h1><%= vehicle.year %> <%= vehicle.make %> <%= vehicle.model %></h1>

    <div class="vehicle-info">
        <p><strong>Price:</strong> $<%= vehicle.price %></p>
        <p><strong>Status:</strong> <%= vehicle.status %></p>
        <p><strong>Description:</strong> <%= vehicle.description %></p>
    </div>

    <!-- Multi-stage Workflow trigger for Service Requests -->
    <% if (user) { %>
        <div class="service-actions">
            <h3>Need Maintenance?</h3>
            <a href="/user/service-requests/new?vehicle_id=<%= vehicle.id %>" class="btn">Request Service</a>
        </div>
    <% } %>

</div>

<hr>

<div class="reviews-section">
    <h2>Customer Reviews</h2>

    <% if (typeof reviews !== 'undefined' && reviews.length > 0) { %>
        <% reviews.forEach(review => { %>
            <div class="review-card">
                <p><strong>Rating:</strong> <%= review.rating %>/5</p>
                <p><%= review.comment %></p>
                <small>By: <%= review.user_name %> on <%= new Date(review.created_at).toLocaleDateString() %></small>
                
                <!-- Let the owner edit/delete their review OR an employee/admin to moderate -->
                <% if (user && (user.id === review.user_id || role === 'Employee' || role === 'Admin')) { %>
                    <form action="/reviews/<%= review.id %>/delete" method="POST" style="display:inline;">
                        <button type="submit" class="btn-danger">Delete Review</button>
                    </form>
                <% } %>
            </div>
        <% }) %>
    <% } else { %>
        <p>There are no reviews for this vehicle yet.</p>
    <% } %>

    <!-- Add Review Form (only for logged-in users) -->
    <% if (user) { %>
        <h3>Write a Review</h3>
        <form action="/reviews" method="POST" class="review-form">
            <input type="hidden" name="vehicle_id" value="<%= vehicle.id %>">
            
            <label for="rating">Rating (1-5):</label>
            <input type="number" id="rating" name="rating" min="1" max="5" required>
            
            <label for="comment">Comment:</label>
            <textarea id="comment" name="comment" required></textarea>
            
            <button type="submit" class="btn">Submit Review</button>
        </form>
    <% } else { %>
        <p><a href="/login">Log in</a> to leave a review!</p>
    <% } %>
</div>

<%- include('../partials/footer') %>