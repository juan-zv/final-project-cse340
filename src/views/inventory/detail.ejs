<%- include('../partials/header') %>

<% const v = typeof vehicle !== 'undefined' ? vehicle : {}; %>
<% const images = Array.isArray(vehicleImages) ? vehicleImages : []; %>

<section class="card glass-panel">
	<h1>
		<%= v.year || 'Vehicle' %>
		<%= v.make || '' %>
		<%= v.model || '' %>
	</h1>
	<p>
		Category:
		<strong><%= v.category || 'Uncategorized' %></strong>
		| Availability:
		<strong><%= v.status || 'Available' %></strong>
	</p>
</section>

<section class="card glass-panel">
	<h2>Photos</h2>
	<% const primaryImage = images.length > 0 ? images[0] : null; %>
	<% const secondaryImages = images.length > 1 ? images.slice(1) : []; %>
	<div style="display:grid; gap: 1rem;">
		<article class="vehicle-card">
			<img class="vehicle-gallery-image vehicle-gallery-primary" src="<%= primaryImage && primaryImage.imagePath ? primaryImage.imagePath : (v.image || v.thumbnail || '/images/default-vehicle.jpg') %>" alt="<%= primaryImage && primaryImage.imageLabel ? primaryImage.imageLabel : 'Vehicle image' %>">
		</article>
		<% if (secondaryImages.length > 0) { %>
			<div class="vehicle-grid">
				<% secondaryImages.forEach((img) => { %>
					<article class="vehicle-card">
						<img class="vehicle-gallery-image" src="<%= img.imagePath || img.url || '/images/default-vehicle.jpg' %>" alt="<%= img.imageLabel || 'Vehicle image' %>">
					</article>
				<% }) %>
			</div>
		<% } %>
	</div>
</section>

<section class="card glass-panel">
	<h2>Vehicle Details</h2>
	<p><strong>Price:</strong> $<%= v.price || 'N/A' %></p>
	<p><strong>Mileage:</strong> <%= v.miles || 'N/A' %></p>
	<p><strong>Color:</strong> <%= v.color || 'N/A' %></p>
	<p><strong>Description:</strong> <%= v.description || 'No description available.' %></p>
</section>

<section class="card glass-panel">
	<h2>Actions</h2>
	<% if (isLoggedIn) { %>
		<p>Signed in users can leave reviews for this vehicle.</p>
		<a class="btn btn-primary" href="/reviews/new?inv_id=<%= v.id || '' %>">Leave a Review</a>
		<% if (role === 'Admin') { %>
			<a class="btn" href="/catalog/<%= v.slug || ('vehicle-' + (v.id || '')) %>/edit">Edit This Vehicle</a>
			<a class="btn" href="/catalog/<%= v.slug || v.id || '' %>/images/new">Add Image</a>
		<% } else if (role === 'Employee') { %>
			<a class="btn" href="/catalog/<%= v.slug || ('vehicle-' + (v.id || '')) %>/edit">Edit This Vehicle</a>
			<a class="btn" href="/catalog/<%= v.slug || v.id || '' %>/images/new">Add Image</a>
		<% } %>
	<% } else { %>
		<p>Log in to leave a review for this vehicle.</p>
		<a class="btn btn-primary" href="/login">Log In to Leave a Review</a>
	<% } %>
</section>

<section class="card glass-panel">
	<h2>Customer Reviews</h2>
	<% const vehicleReviews = Array.isArray(reviews) ? reviews : []; %>
	<% if (vehicleReviews.length > 0) { %>
		<% vehicleReviews.forEach((review) => { %>
			<article class="card glass-panel" style="margin: 1rem 0;">
				<p><%= review.reviewText || '' %></p>
				<p>
					By <%= review.accountFirstName || 'Customer' %>
					on <%= review.reviewDate ? new Date(review.reviewDate).toLocaleDateString() : 'N/A' %>
				</p>

				<% const currentUserId = Number(user && (user.id ?? user.account_id)); %>
				<% const reviewOwnerId = Number(review.accountId); %>
				<% const canEditOwn = Number.isFinite(currentUserId) && currentUserId === reviewOwnerId; %>
				<% const canModerate = role === 'Employee' || role === 'Admin'; %>

				<% if (canEditOwn || canModerate) { %>
					<form action="/reviews/<%= review.reviewId %>/delete" method="POST" style="display:inline-block;">
						<input type="hidden" name="returnTo" value="/catalog/<%= v.slug || v.id || '' %>">
						<button type="submit" class="btn">Delete Review</button>
					</form>
				<% } %>
			</article>
		<% }) %>
	<% } else { %>
		<p>No reviews have been posted for this vehicle yet.</p>
	<% } %>
</section>

<%- include('../partials/footer') %>
