<%- include('../partials/header') %>

<h1>Vehicle Inventory</h1>

<% if (isLoggedIn) { %>
	<section class="card" style="margin-bottom: 1rem;">
		<p>Welcome back<%= user && user.name ? `, ${user.name}` : '' %>. You are signed in.</p>
		<% if (role === 'Admin') { %>
			<a href="/admin/dashboard" class="btn btn-primary">Manage Inventory</a>
		<% } else if (role === 'Employee') { %>
			<a href="/dashboard" class="btn btn-primary">Employee Inventory Tools</a>
		<% } else { %>
			<a href="/dashboard" class="btn btn-primary">Go to My Dashboard</a>
		<% } %>
	</section>
<% } else { %>
	<section class="card" style="margin-bottom: 1rem;">
		<p>Sign in to unlock dashboard tools and faster service request workflows.</p>
		<a href="/login" class="btn">Log In</a>
	</section>
<% } %>

<div class="filters">
	<form action="/catalog" method="GET">
		<label for="category">Filter by Category:</label>
		<select name="category" id="category" onchange="this.form.submit()">
			<option value="" <%= currentCategory === '' ? 'selected' : '' %>>All Vehicles</option>
			<option value="Trucks" <%= currentCategory === 'Trucks' ? 'selected' : '' %>>Trucks</option>
			<option value="Vans" <%= currentCategory === 'Vans' ? 'selected' : '' %>>Vans</option>
			<option value="Cars" <%= currentCategory === 'Cars' ? 'selected' : '' %>>Cars</option>
			<option value="SUVs" <%= currentCategory === 'SUVs' ? 'selected' : '' %>>SUVs</option>
		</select>

		<label for="sortBy">Sort by:</label>
		<select name="sortBy" id="sortBy" onchange="this.form.submit()">
			<option value="newest" <%= currentSort === 'newest' ? 'selected' : '' %>>Newest Year</option>
			<option value="oldest" <%= currentSort === 'oldest' ? 'selected' : '' %>>Oldest Year</option>
			<option value="make_asc" <%= currentSort === 'make_asc' ? 'selected' : '' %>>Make A-Z</option>
			<option value="make_desc" <%= currentSort === 'make_desc' ? 'selected' : '' %>>Make Z-A</option>
			<option value="price_low" <%= currentSort === 'price_low' ? 'selected' : '' %>>Price Low to High</option>
			<option value="price_high" <%= currentSort === 'price_high' ? 'selected' : '' %>>Price High to Low</option>
		</select>
	</form>
</div>

<div class="vehicle-grid">
	<% if (typeof vehicles !== 'undefined' && vehicles.length > 0) { %>
		<% vehicles.forEach(v => { %>
			<article class="vehicle-card">
				<img
					src="<%= v.image %>"
					alt="<%= `${v.year} ${v.make} ${v.model}` %>"
					class="catalog-primary-thumb"
					loading="lazy"
				>
				<div class="vehicle-card-body">
					<h2><%= v.year %> <%= v.make %> <%= v.model %></h2>
					<p class="vehicle-card-meta">
						<span class="status">Status: <%= v.status %></span>
						<span><%= v.category %></span>
					</p>
					<p class="vehicle-card-price">$<%= Number(v.price).toLocaleString('en-US') %></p>
					<p class="vehicle-card-description">
						<%= v.description && v.description.length > 160 ? `${v.description.slice(0, 157)}...` : (v.description || 'No description provided.') %>
					</p>
					<a href="/catalog/<%= v.slug %>" class="btn">View Details</a>
				</div>
			</article>
		<% }) %>
	<% } else { %>
		<p>No vehicles found matching your criteria.</p>
	<% } %>
</div>

<%- include('../partials/footer') %>
