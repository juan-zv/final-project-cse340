<%- include('partials/header') %>

<div class="home-container">
    <section class="hero">
        <div class="hero-content">
            <h1>Welcome to Juansito's Car Dealership</h1>
            <p>Welcome to Juansito's, where drivers find dependable vehicles, honest pricing, and trusted support.</p>
            <p>Browse quality inventory, leave verified reviews, and manage service requests from one place.</p>
            <div class="hero-metrics">
                <span class="metric-pill">Transparent Pricing</span>
                <span class="metric-pill">Fast Online Support</span>
                <span class="metric-pill">Service Tracking</span>
            </div>
            <nav class="hero-nav">
                <a href="/catalog" class="btn btn-primary">Browse Inventory</a>
                <% if (isLoggedIn) { %>
                    <a href="/dashboard" class="btn btn-secondary">Open Dashboard</a>
                <% } else { %>
                    <a href="/login" class="btn btn-secondary">Log In</a>
                    <a href="/register" class="btn btn-outline">Create Account</a>
                <% } %>
            </nav>
        </div>
    </section>

    <section class="categories">
        <h2>Browse by Category</h2>
        <div class="category-grid">
            <a href="/catalog?category=Cars" class="category-card"><h3>Cars</h3></a>
            <a href="/catalog?category=Trucks" class="category-card"><h3>Trucks</h3></a>
            <a href="/catalog?category=SUVs" class="category-card"><h3>SUVs</h3></a>
            <a href="/catalog?category=Vans" class="category-card"><h3>Vans</h3></a>
        </div>
    </section>

    <section class="featured-vehicles">
        <div class="section-header">
            <h2>Featured Vehicles</h2>
            <a href="/catalog" class="btn btn-small">View All</a>
        </div>
        <div class="vehicle-grid">
            <% if (typeof featuredVehicles !== 'undefined' && featuredVehicles.length > 0) { %>
                <% featuredVehicles.forEach((vehicle) => { %>
                    <article class="vehicle-card">
                        <img src="<%= vehicle.thumbnail || vehicle.image || '/images/default-vehicle.jpg' %>" alt="<%= vehicle.make %> <%= vehicle.model %>">
                        <h3><%= vehicle.year %> <%= vehicle.make %> <%= vehicle.model %></h3>
                        <p class="price">$<%= vehicle.price %></p>
                        <p class="vehicle-meta"><%= vehicle.category || 'Vehicle' %> • <%= vehicle.status || 'Available' %></p>
                        <a href="/catalog/<%= vehicle.slug || vehicle.id %>" class="btn btn-small">View Details</a>
                    </article>
                <% }) %>
            <% } else { %>
                <article class="vehicle-card">
                    <img src="/images/default-vehicle.jpg" alt="Vehicle placeholder">
                    <h3>Inventory updates are in progress</h3>
                    <p class="price">Check back shortly</p>
                    <a href="/catalog" class="btn btn-small">Open Catalog</a>
                </article>
            <% } %>
        </div>
    </section>

    <section class="contact-cta">
        <h2>Need Maintenance or Have Questions?</h2>
        <p>The Juansito's team is ready to help. Contact us directly or open a service request to track updates from start to finish.</p>
        <div class="cta-links">
            <a href="/contact" class="btn btn-secondary">Contact Us</a>
            <a href="<%= isLoggedIn ? '/services/request' : '/login' %>" class="btn btn-outline"><%= isLoggedIn ? 'Request Service' : 'Log In to Request Service' %></a>
        </div>
    </section>

</div>

<%- include('partials/footer') %>