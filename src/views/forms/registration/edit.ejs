<%- include('../../partials/header') %>

<section class="card glass-panel">
    <h1>Edit Account</h1>
    <p>Update account name, email, and role details.</p>
</section>

<section class="card glass-panel">
    <form action="/register/<%= user && user.id ? user.id : '' %>/edit" method="POST">
        <label for="name">Name</label>
        <input
            id="name"
            name="name"
            type="text"
            minlength="2"
            maxlength="100"
            required
            value="<%= user && user.name ? user.name : '' %>"
        >

        <label for="email">Email</label>
        <input
            id="email"
            name="email"
            type="email"
            required
            value="<%= user && user.email ? user.email : '' %>"
        >

        <% if (typeof isAdminEditing !== 'undefined' && isAdminEditing) { %>
            <label for="account_type">Role</label>
            <select id="account_type" name="account_type" required>
                <option value="User" <%= user && (user.roleName || 'User') === 'User' ? 'selected' : '' %>>User</option>
                <option value="Employee" <%= user && user.roleName === 'Employee' ? 'selected' : '' %>>Employee</option>
                <option value="Admin" <%= user && user.roleName === 'Admin' ? 'selected' : '' %>>Admin</option>
            </select>
        <% } %>

        <button type="submit" class="btn btn-primary">Save Changes</button>
        <a class="btn" href="/dashboard/users">Back to List</a>
    </form>
</section>

<%- include('../../partials/footer') %>
